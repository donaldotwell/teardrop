server {
    listen 127.0.0.1:80;
    listen [::1]:80;
    server_name __DOMAIN__;

    root __PROJECT_ROOT__/public;
    index index.php;

    # === Critical opsec: no visitor logging ===
    access_log off;
    error_log /var/log/nginx/__PROJECT_NAME__.error.log warn;

    # === Hard limit: 10 MB max upload size (Laravel + PHP + Nginx) ===
    client_max_body_size 10M;                     # Nginx level
    # (Make sure you also set in php.ini: upload_max_filesize = 10M and post_max_size = 11M)

    # === Anti-abuse timeouts (prevents Slowloris, slow POST, idle attacks) ===
    client_body_timeout   15s;   # How long to wait for full request body (upload)
    client_header_timeout 15s;   # How long to wait for full headers
    send_timeout          15s;   # How long to wait when sending response
    lingering_timeout     10s;   # After final packet, how long to keep connection open
    keepalive_timeout     10s;   # Close idle keep-alives quickly
    keepalive_requests    50;    # Close connection after 50 requests (prevents long-lived abuse)

    # Reset timed-out or abnormally slow connections immediately
    reset_timedout_connection on;

    # === Security headers ===
    add_header X-Frame-Options            "DENY" always;
    add_header X-Content-Type-Options     "nosniff" always;
    add_header X-XSS-Protection           "1; mode=block" always;
    add_header Referrer-Policy            "no-referrer" always;
    add_header Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    add_header Permissions-Policy         "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;

    server_tokens off;
    fastcgi_hide_header X-Powered-By;

    charset utf-8;

    # Laravel routing
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Static files (no logging, long caching)
    location = /favicon.ico  { access_log off; log_not_found off; expires 1y; add_header Cache-Control "public, immutable"; }
    location = /robots.txt   { access_log off; log_not_found off; }
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Block hidden files and sensitive paths
    location ~ /\.(?!well-known).* { deny all; access_log off; log_not_found off; }
    location ~* (/\.git|/\.env|\.log|backup|composer\.json|composer\.lock|node_modules) {
        deny all; access_log off; log_not_found off;
    }

    # PHP handling – only index.php is ever executed
    location ~ ^/index\.php(/|$) {
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;

        fastcgi_param HTTP_PROXY "";
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_index index.php;

        # Additional timeouts specific to PHP
        fastcgi_read_timeout 60s;      # Give PHP up to 60s for long operations (e.g. encrypting large files)
        fastcgi_send_timeout 60s;

        internal;
    }

    # Deny all other .php access
    location ~ \.php$ {
        return 404;
    }

    # Block common attack paths instantly
    location ~* (wp-admin|wp-login|\.env|\.git|phpmyadmin) {
        return 444;
    }

    error_page 404 /index.php;
}