server {
    listen 127.0.0.1:80;
    listen [::1]:80 ipv6only=on;
    server_name __DOMAIN__;

    root __PROJECT_ROOT__/public;
    index index.php;

    access_log off;
    error_log /var/log/nginx/__PROJECT_NAME__.error.log warn;

    client_max_body_size 10M;

    client_body_timeout   15s;
    client_header_timeout 15s;
    send_timeout          15s;
    lingering_timeout     10s;
    keepalive_timeout     10s;
    keepalive_requests    50;
    reset_timedout_connection on;

    add_header X-Frame-Options            "DENY" always;
    add_header X-Content-Type-Options     "nosniff" always;
    add_header X-XSS-Protection           "1; mode=block" always;
    add_header Referrer-Policy            "no-referrer" always;
    add_header Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    add_header Permissions-Policy         "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;

    server_tokens off;
    fastcgi_hide_header X-Powered-By;
    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico  { access_log off; log_not_found off; expires 1y; add_header Cache-Control "public, immutable"; }
    location = /robots.txt   { access_log off; log_not_found off; }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location ~ /\.(?!well-known).* { deny all; access_log off; log_not_found off; }
    location ~* (/\.git|/\.env|\.log|backup|composer\.json|composer\.lock|node_modules) {
        deny all; access_log off; log_not_found off;
    }

    location ~* (wp-admin|wp-login|\.env|\.git|phpmyadmin) {
        return 444;
    }

    location ~ ^/index\.php(/|$) {
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/php__PHP_VERSION__-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTP_PROXY "";
        include fastcgi_params;
        fastcgi_read_timeout 60s;
        fastcgi_send_timeout 60s;
        internal;
    }

    location ~ \.php$ { return 404; }

    error_page 404 /index.php;
}

server {
    listen 127.0.0.1:443 ssl;
    listen [::1]:443 ssl ipv6only=on;
    server_name __DOMAIN__;

    ssl_certificate     __SSL_CERT__;
    ssl_certificate_key __SSL_KEY__;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    root __PROJECT_ROOT__/public;
    index index.php;

    access_log off;
    error_log /var/log/nginx/__PROJECT_NAME__.error.log warn;

    client_max_body_size 10M;

    client_body_timeout   15s;
    client_header_timeout 15s;
    send_timeout          15s;
    lingering_timeout     10s;
    keepalive_timeout     10s;
    keepalive_requests    50;
    reset_timedout_connection on;

    add_header X-Frame-Options            "DENY" always;
    add_header X-Content-Type-Options     "nosniff" always;
    add_header X-XSS-Protection           "1; mode=block" always;
    add_header Referrer-Policy            "no-referrer" always;
    add_header Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    add_header Permissions-Policy         "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;
    add_header Strict-Transport-Security  "max-age=31536000; includeSubDomains" always;

    server_tokens off;
    fastcgi_hide_header X-Powered-By;
    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico  { access_log off; log_not_found off; expires 1y; add_header Cache-Control "public, immutable"; }
    location = /robots.txt   { access_log off; log_not_found off; }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location ~ /\.(?!well-known).* { deny all; access_log off; log_not_found off; }
    location ~* (/\.git|/\.env|\.log|backup|composer\.json|composer\.lock|node_modules) {
        deny all; access_log off; log_not_found off;
    }

    location ~* (wp-admin|wp-login|\.env|\.git|phpmyadmin) {
        return 444;
    }

    location ~ ^/index\.php(/|$) {
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/php__PHP_VERSION__-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTP_PROXY "";
        include fastcgi_params;
        fastcgi_read_timeout 60s;
        fastcgi_send_timeout 60s;
        internal;
    }

    location ~ \.php$ { return 404; }

    error_page 404 /index.php;
}