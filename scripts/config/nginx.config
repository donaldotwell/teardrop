# These two directives must be in the http context.
# If this file is included from within a server block, move them to nginx.conf.
limit_req_zone $binary_remote_addr zone=php_fpm:10m rate=50r/s;
limit_req_status 429;

server {
    listen 127.0.0.1:80;
    listen [::1]:80 ipv6only=on;
    server_name __DOMAIN__;

    root __PROJECT_ROOT__/public;
    index index.php;

    access_log off;
    error_log /var/log/nginx/__PROJECT_NAME__.error.log warn;

    client_max_body_size 10M;

    client_body_timeout   15s;
    client_header_timeout 15s;
    send_timeout          15s;
    lingering_timeout     10s;
    keepalive_timeout     10s;
    keepalive_requests    50;
    reset_timedout_connection on;

    # Security headers applied to all responses that don't have their own
    # add_header block. Locations with local add_header directives must repeat
    # these explicitly — nginx does NOT inherit parent add_header when a location
    # defines its own.
    add_header X-Frame-Options              "DENY" always;
    add_header X-Content-Type-Options       "nosniff" always;
    add_header X-XSS-Protection             "1; mode=block" always;
    add_header Referrer-Policy              "no-referrer" always;
    add_header Content-Security-Policy      "default-src 'self'; script-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    add_header Permissions-Policy           "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;
    add_header Cross-Origin-Opener-Policy   "same-origin" always;
    add_header Cross-Origin-Resource-Policy "same-origin" always;
    add_header Origin-Agent-Cluster         "?1" always;

    server_tokens off;
    fastcgi_hide_header X-Powered-By;
    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico {
        access_log off;
        log_not_found off;
        expires 1y;
        add_header Cache-Control              "public, immutable" always;
        add_header X-Content-Type-Options     "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
    }

    location = /robots.txt { access_log off; log_not_found off; }

    # Static assets — long cache + required security headers repeated explicitly
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control              "public, immutable" always;
        add_header X-Content-Type-Options     "nosniff" always;
        add_header X-Frame-Options            "DENY" always;
        add_header Referrer-Policy            "no-referrer" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        access_log off;
    }

    location ~ /\.(?!well-known).* { deny all; access_log off; log_not_found off; }
    location ~* (/\.git|/\.env|\.log|backup|composer\.json|composer\.lock|node_modules) {
        deny all; access_log off; log_not_found off;
    }

    location ~* (wp-admin|wp-login|\.env|\.git|phpmyadmin) {
        return 444;
    }

    location ~ ^/index\.php(/|$) {
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/php__PHP_VERSION__-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTP_PROXY "";
        include fastcgi_params;
        fastcgi_read_timeout 60s;
        fastcgi_send_timeout 60s;

        # Full security header set repeated here (add_header inheritance is broken
        # when any local add_header exists in the same location block).
        add_header X-Frame-Options              "DENY" always;
        add_header X-Content-Type-Options       "nosniff" always;
        add_header X-XSS-Protection             "1; mode=block" always;
        add_header Referrer-Policy              "no-referrer" always;
        add_header Content-Security-Policy      "default-src 'self'; script-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        add_header Permissions-Policy           "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;
        add_header Cross-Origin-Opener-Policy   "same-origin" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Origin-Agent-Cluster         "?1" always;
        # Dynamic responses must never be stored in any cache (browser or proxy)
        add_header Cache-Control                "no-store, no-cache, must-revalidate" always;

        # Secondary DoS circuit-breaker. Laravel's session-based throttle handles
        # per-user fairness; this caps raw PHP-FPM throughput if the Tor service
        # is flooded. All hidden-service traffic shares 127.0.0.1 so the zone
        # acts as a global PHP rate cap, not per-user.
        limit_req zone=php_fpm burst=100 nodelay;

        internal;
    }

    location ~ \.php$ { return 404; }

    error_page 404 /index.php;
}

server {
    listen 127.0.0.1:443 ssl;
    listen [::1]:443 ssl ipv6only=on;
    server_name __DOMAIN__;

    ssl_certificate     __SSL_CERT__;
    ssl_certificate_key __SSL_KEY__;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    root __PROJECT_ROOT__/public;
    index index.php;

    access_log off;
    error_log /var/log/nginx/__PROJECT_NAME__.error.log warn;

    client_max_body_size 10M;

    client_body_timeout   15s;
    client_header_timeout 15s;
    send_timeout          15s;
    lingering_timeout     10s;
    keepalive_timeout     10s;
    keepalive_requests    50;
    reset_timedout_connection on;

    add_header X-Frame-Options              "DENY" always;
    add_header X-Content-Type-Options       "nosniff" always;
    add_header X-XSS-Protection             "1; mode=block" always;
    add_header Referrer-Policy              "no-referrer" always;
    add_header Content-Security-Policy      "default-src 'self'; script-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    add_header Permissions-Policy           "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;
    # 2-year max-age required for HSTS preload list submission
    add_header Strict-Transport-Security    "max-age=63072000; includeSubDomains; preload" always;
    add_header Cross-Origin-Opener-Policy   "same-origin" always;
    add_header Cross-Origin-Resource-Policy "same-origin" always;
    add_header Origin-Agent-Cluster         "?1" always;

    server_tokens off;
    fastcgi_hide_header X-Powered-By;
    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico {
        access_log off;
        log_not_found off;
        expires 1y;
        add_header Cache-Control              "public, immutable" always;
        add_header X-Content-Type-Options     "nosniff" always;
        add_header Strict-Transport-Security  "max-age=63072000; includeSubDomains; preload" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
    }

    location = /robots.txt { access_log off; log_not_found off; }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control              "public, immutable" always;
        add_header X-Content-Type-Options     "nosniff" always;
        add_header X-Frame-Options            "DENY" always;
        add_header Referrer-Policy            "no-referrer" always;
        add_header Strict-Transport-Security  "max-age=63072000; includeSubDomains; preload" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        access_log off;
    }

    location ~ /\.(?!well-known).* { deny all; access_log off; log_not_found off; }
    location ~* (/\.git|/\.env|\.log|backup|composer\.json|composer\.lock|node_modules) {
        deny all; access_log off; log_not_found off;
    }

    location ~* (wp-admin|wp-login|\.env|\.git|phpmyadmin) {
        return 444;
    }

    location ~ ^/index\.php(/|$) {
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/php__PHP_VERSION__-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTP_PROXY "";
        include fastcgi_params;
        fastcgi_read_timeout 60s;
        fastcgi_send_timeout 60s;

        add_header X-Frame-Options              "DENY" always;
        add_header X-Content-Type-Options       "nosniff" always;
        add_header X-XSS-Protection             "1; mode=block" always;
        add_header Referrer-Policy              "no-referrer" always;
        add_header Content-Security-Policy      "default-src 'self'; script-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        add_header Permissions-Policy           "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;
        add_header Strict-Transport-Security    "max-age=63072000; includeSubDomains; preload" always;
        add_header Cross-Origin-Opener-Policy   "same-origin" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Origin-Agent-Cluster         "?1" always;
        add_header Cache-Control                "no-store, no-cache, must-revalidate" always;

        limit_req zone=php_fpm burst=100 nodelay;

        internal;
    }

    location ~ \.php$ { return 404; }

    error_page 404 /index.php;
}
